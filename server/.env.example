# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/halocab

# JWT
JWT_SECRET=halocab_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Stripe (Test Keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Redis (optional - falls back to in-memory)
REDIS_URL=redis://localhost:6379

# Frontend URL
CLIENT_URL=http://localhost:5173

# Pricing
BASE_FARE_CAB=50
BASE_FARE_BIKE=20
PER_KM_CAB=12
PER_KM_BIKE=7
PER_MIN_CAB=2
PER_MIN_BIKE=1
